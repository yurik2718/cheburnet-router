[Interface]
Address = 10.x.x.x/32
DNS = 100.64.0.1, 8.8.4.4
PrivateKey = REPLACE_WITH_YOUR_KEY

# AmneziaWG v1.0 параметры обфускации (от Amnezia-клиента):
Jc = 4
Jmin = 10
Jmax = 50
S1 = 82
S2 = 44
H1 = 1754556670
H2 = 323984459
H3 = 1156386384
H4 = 1526318555

# AmneziaWG v1.5 — дополнительный слой обфускации (Custom Protocol Signature).
# I1 = decoy-пакет, который уходит перед реальным handshake и выглядит как обычный
# DNS-ответ. Пример-значение из официальной документации Amnezia
# (https://docs.amnezia.org/documentation/instructions/upgrade-awg-config/):
I1 = <r 2><b 0x8580000100010000000004796162730679616e6465780272750000010001c00c000100010001c00c000100010000026d000457fa27d1>

[Peer]
PublicKey = REPLACE_WITH_YOUR_KEY
PresharedKey = REPLACE_WITH_YOUR_KEY
AllowedIPs = 0.0.0.0/0, ::/0
Endpoint = your.server.ip:PORT
PersistentKeepalive = 25
