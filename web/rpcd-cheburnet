#!/bin/sh
# rpcd-cheburnet — ubus-RPC handler для веб-мастера cheburnet-router.
# Ставится в /usr/libexec/rpcd/cheburnet и автоматически подхватывается rpcd.
#
# Методы:
#   get_status         — состояние системы (режим, установлен ли VPN, handshake AWG, running-сервисы)
#   install_start      — запустить установку (ssid, wifi_key, country, awg_conf, root_pass)
#   install_progress   — текущий шаг + последние 5000 байт логов + done-флаг
#   install_cancel     — пометить установку как отменённую (реально не убивает процесс)
#   mode_switch        — переключить HOME/TRAVEL
#   service_restart    — перезапустить сервис (vpn | dns | adblock)
#
# Протокол rpcd: скрипт вызывается с аргументами `list` или `call <method>`.
# В режиме `call` аргументы метода читаются из stdin как JSON.

INSTALL_DIR="${INSTALL_DIR:-/opt/cheburnet}"
STATE_DIR="${STATE_DIR:-/tmp/cheburnet}"
LOG_FILE="$STATE_DIR/install.log"
STATE_FILE="$STATE_DIR/state"
DONE_FILE="$STATE_DIR/done"
PID_FILE="$STATE_DIR/pid"

# Системные пути роутера. По умолчанию — стандартные OpenWrt-локации;
# integration-тесты переопределяют их через env, чтобы запустить скрипт в
# sandbox без реального /etc /usr и /etc/init.d.
ETC_CHEBURNET="${ETC_CHEBURNET:-/etc/cheburnet}"
ETC_AWG_DIR="${ETC_AWG_DIR:-/etc/amnezia/amneziawg}"
ETC_ADBLOCK_CFG="${ETC_ADBLOCK_CFG:-/etc/adblock-lean/config}"
ETC_INIT_D="${ETC_INIT_D:-/etc/init.d}"
ETC_VPN_MODE_STATE="${ETC_VPN_MODE_STATE:-/etc/vpn-mode.state}"
USR_BIN_VPN_MODE="${USR_BIN_VPN_MODE:-/usr/bin/vpn-mode}"

mkdir -p "$STATE_DIR"

# === Подключаем общие pure-функции (json_escape, валидаторы) ===
# Файл ставится bootstrap.sh в /opt/cheburnet/lib/. Fallback на относительный
# путь — для запуска из репо-чекаута (тесты, отладка).
LIB="${CHEBURNET_LIB:-$INSTALL_DIR/lib/cheburnet-utils.sh}"
[ -f "$LIB" ] || LIB="$(dirname "$0")/../../../opt/cheburnet/lib/cheburnet-utils.sh"
# shellcheck source=../lib/cheburnet-utils.sh disable=SC1090,SC1091
. "$LIB"

# === list: описание доступных методов ===
if [ "$1" = "list" ]; then
    cat <<'EOF'
{
    "get_status": {},
    "install_start": {
        "ssid": "str",
        "wifi_key": "str",
        "country": "str",
        "awg_conf": "str",
        "root_pass": "str",
        "token": "str"
    },
    "install_progress": {},
    "install_cancel": {},
    "mode_switch": { "mode": "str" },
    "service_restart": { "service": "str" },
    "set_blocklist_tier": { "tier": "str" },
    "factory_reset": { "confirm": "str" }
}
EOF
    exit 0
fi

# === call: вызов метода ===
if [ "$1" != "call" ]; then
    echo '{"error":"unknown action"}' >&2
    exit 1
fi

METHOD="$2"
INPUT=$(cat)

# jsonfilter helper — возвращает пустую строку при отсутствии поля
jf() {
    echo "$INPUT" | jsonfilter -e "$1" 2>/dev/null || true
}

case "$METHOD" in

    # ------------------------------------------------------------------
    get_status)
        MODE=$(cat "$ETC_VPN_MODE_STATE" 2>/dev/null || echo "unknown")

        # Определяем тип установки
        INSTALL_TYPE="none"
        if [ -f "$ETC_AWG_DIR/awg0.conf" ] && [ -x "$ETC_INIT_D/podkop" ]; then
            INSTALL_TYPE="vpn"
        fi

        # Установка в процессе?
        INSTALLING="false"
        [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null && INSTALLING="true"

        # Сервисы running?
        ADBLOCK_UP="false"
        "$ETC_INIT_D/adblock-lean" status 2>&1 | grep -qi running && ADBLOCK_UP="true"

        PODKOP_UP="false"
        "$ETC_INIT_D/sing-box" status 2>&1 | grep -qi running && PODKOP_UP="true"

        # DNS — отдельный probe: dnsmasq running + резолвится тестовый домен
        # Лейбл «DNS (DoH)» в UI описывает работу sing-box-DoH через dnsmasq;
        # podkop_up недостаточен — dnsmasq может упасть отдельно.
        DNS_UP="false"
        if "$ETC_INIT_D/dnsmasq" status 2>&1 | grep -qi running; then
            LAN_IP=$(uci -q get network.lan.ipaddr || echo "127.0.0.1")
            if nslookup cloudflare.com "$LAN_IP" 2>/dev/null | grep -q Address; then
                DNS_UP="true"
            fi
        fi

        # AWG handshake age
        AWG_HS_AGE="null"
        HS=$(awg show awg0 latest-handshakes 2>/dev/null | awk '{print $2}')
        if [ -n "$HS" ] && [ "$HS" -gt 0 ]; then
            AWG_HS_AGE=$(( $(date +%s) - HS ))
        fi

        # Wi-Fi SSID — пропускаем через JSON-escape (может содержать ", \, и т.д.)
        SSID_RAW=$(uci -q get wireless.default_radio0.ssid || echo "")
        SSID=$(json_escape "$SSID_RAW")
        MODE_ESC=$(json_escape "$MODE")

        # Текущий тир Hagezi из adblock-lean config
        TIER_RAW=$(grep -E '^raw_block_lists=' "$ETC_ADBLOCK_CFG" 2>/dev/null \
            | sed -e 's/^raw_block_lists="\?//' -e 's/"\?$//' -e 's/hagezi://' | head -1)
        TIER=$(json_escape "${TIER_RAW:-pro}")

        # Признак pre-install режима: токен на месте — значит ждём install_start
        TOKEN_PRESENT="false"
        [ -s "$ETC_CHEBURNET/install-token" ] && TOKEN_PRESENT="true"

        cat <<EOF
{
    "install_type": "$INSTALL_TYPE",
    "installing": $INSTALLING,
    "install_token_required": $TOKEN_PRESENT,
    "mode": "$MODE_ESC",
    "ssid": "$SSID",
    "adblock_up": $ADBLOCK_UP,
    "podkop_up": $PODKOP_UP,
    "dns_up": $DNS_UP,
    "awg_handshake_age": $AWG_HS_AGE,
    "blocklist_tier": "$TIER"
}
EOF
        ;;

    # ------------------------------------------------------------------
    install_start)
        # Проверяем, не идёт ли уже установка
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo '{"error": "installation already running", "pid": '"$(cat "$PID_FILE")"'}'
            exit 0
        fi

        # === Проверка install-токена ===
        # Защита от LAN-сквоттинга: даже unauth-вызов должен предъявить токен,
        # выданный bootstrap.sh в /etc/cheburnet/install-token. После успешной
        # установки run-install.sh удаляет файл — повторно установить нельзя
        # без нового bootstrap-запуска.
        TOKEN_FILE="$ETC_CHEBURNET/install-token"
        if [ ! -s "$TOKEN_FILE" ]; then
            echo '{"error": "install token not found — router is already installed or bootstrap.sh did not run. Re-run bootstrap.sh via SSH to get a new token."}'
            exit 0
        fi
        EXPECTED_TOKEN=$(cat "$TOKEN_FILE")
        GIVEN_TOKEN=$(jf '@.token')
        if [ -z "$GIVEN_TOKEN" ] || [ "$GIVEN_TOKEN" != "$EXPECTED_TOKEN" ]; then
            echo '{"error": "invalid install token — see SSH output of bootstrap.sh"}'
            exit 0
        fi

        SSID=$(jf '@.ssid')
        WIFI_KEY=$(jf '@.wifi_key')
        COUNTRY=$(jf '@.country')
        AWG_CONF=$(jf '@.awg_conf')
        ROOT_PASS=$(jf '@.root_pass')

        # Валидация
        [ -z "$SSID" ]     && { echo '{"error": "ssid required"}'; exit 0; }
        [ -z "$WIFI_KEY" ] && { echo '{"error": "wifi_key required"}'; exit 0; }
        [ "${#WIFI_KEY}" -lt 8 ] && { echo '{"error": "wifi_key must be >= 8 chars"}'; exit 0; }
        [ -z "$COUNTRY" ]  && COUNTRY="RU"
        [ -z "$ROOT_PASS" ] && { echo '{"error": "root_pass required"}'; exit 0; }
        [ "${#ROOT_PASS}" -lt 8 ] && { echo '{"error": "root_pass must be >= 8 chars"}'; exit 0; }

        [ -z "$AWG_CONF" ] && { echo '{"error": "awg_conf required"}'; exit 0; }
        echo "$AWG_CONF" | grep -q '\[Interface\]' || { echo '{"error": "awg_conf does not contain [Interface] section"}'; exit 0; }
        echo "$AWG_CONF" | grep -q 'PrivateKey'    || { echo '{"error": "awg_conf does not contain PrivateKey"}'; exit 0; }
        echo "$AWG_CONF" | grep -q '\[Peer\]'      || { echo '{"error": "awg_conf does not contain [Peer] section"}'; exit 0; }

        # Сохраняем .conf для 01-amneziawg.sh
        mkdir -p "$ETC_AWG_DIR"
        printf '%s\n' "$AWG_CONF" > "$ETC_AWG_DIR/awg0.conf"
        chmod 600 "$ETC_AWG_DIR/awg0.conf"

        # Передаём root-пароль run-install.sh через короткоживущий файл (chmod 600)
        umask 077
        printf '%s' "$ROOT_PASS" > "$STATE_DIR/root_pass"
        chmod 600 "$STATE_DIR/root_pass"
        unset ROOT_PASS

        # Сохраняем Wi-Fi-параметры для 05-wifi.sh
        cat > "$INSTALL_DIR/configs/wireless-actual.txt" <<EOF
WIFI_SSID="$SSID"
WIFI_KEY="$WIFI_KEY"
WIFI_COUNTRY="$COUNTRY"
EOF
        chmod 600 "$INSTALL_DIR/configs/wireless-actual.txt"

        # Чистим старые артефакты
        rm -f "$DONE_FILE" "$LOG_FILE" "$STATE_FILE"
        echo "starting" > "$STATE_FILE"

        # setsid создаёт новую process-group (PGID=PID), чтобы install_cancel
        # мог убить весь дочерний дерево через kill -- -PID.
        nohup setsid "$INSTALL_DIR/run-install.sh" \
            > "$LOG_FILE" 2>&1 &
        PID=$!
        echo "$PID" > "$PID_FILE"

        echo "{\"status\": \"started\", \"pid\": $PID}"
        ;;

    # ------------------------------------------------------------------
    install_progress)
        # Текущий шаг
        STEP_RAW=$(cat "$STATE_FILE" 2>/dev/null || echo "idle")
        STEP=$(json_escape "$STEP_RAW")

        # Процесс жив?
        RUNNING="false"
        if [ -f "$PID_FILE" ]; then
            kill -0 "$(cat "$PID_FILE")" 2>/dev/null && RUNNING="true"
        fi

        # Установка завершилась?
        DONE="false"
        RESULT="unknown"
        if [ -f "$DONE_FILE" ]; then
            DONE="true"
            RESULT=$(json_escape "$(cat "$DONE_FILE")")
        elif [ "$RUNNING" = "false" ] && [ -f "$LOG_FILE" ]; then
            # Процесс уже не живой, но done-маркер не записан →
            # orchestrator упал/был убит. Сообщаем UI как ошибку.
            DONE="true"
            RESULT="crashed"
        fi

        # Последние 5000 байт лога с JSON-escape
        LOG_RAW=$(tail -c 5000 "$LOG_FILE" 2>/dev/null || echo "")
        LOG=$(json_escape "$LOG_RAW")

        cat <<EOF
{
    "step": "$STEP",
    "running": $RUNNING,
    "done": $DONE,
    "result": "$RESULT",
    "log": "$LOG"
}
EOF
        ;;

    # ------------------------------------------------------------------
    install_cancel)
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE")
            kill "$PID" 2>/dev/null || true
            # kill всей process-группы (в fork'ах могут висеть apk/wget)
            kill -- -"$PID" 2>/dev/null || true
            echo "cancelled" > "$DONE_FILE"
            echo '{"status": "cancelled"}'
        else
            echo '{"status": "not_running"}'
        fi
        ;;

    # ------------------------------------------------------------------
    mode_switch)
        NEW_MODE=$(jf '@.mode')
        if ! cheburnet_valid_mode "$NEW_MODE"; then
            echo '{"error": "mode must be home or travel"}'; exit 0
        fi

        if [ ! -x "$USR_BIN_VPN_MODE" ]; then
            echo '{"error": "vpn-mode CLI not installed — установите VPN-режим"}'
            exit 0
        fi

        OUT=$("$USR_BIN_VPN_MODE" "$NEW_MODE" 2>&1) || {
            echo "{\"error\": \"vpn-mode $NEW_MODE failed\", \"output\": \"$(echo "$OUT" | tr '\n' ' ')\"}"
            exit 0
        }
        echo "{\"status\": \"ok\", \"mode\": \"$NEW_MODE\"}"
        ;;

    # ------------------------------------------------------------------
    service_restart)
        SVC=$(jf '@.service')
        case "$SVC" in
            vpn)
                # Полный рестарт VPN-стека
                ifdown awg0 2>/dev/null; sleep 1; ifup awg0 2>/dev/null
                "$ETC_INIT_D/podkop" restart >/dev/null 2>&1 &
                echo '{"status": "vpn restarting"}'
                ;;
            dns)
                "$ETC_INIT_D/dnsmasq" restart >/dev/null 2>&1
                echo '{"status": "dns restarted"}'
                ;;
            adblock)
                "$ETC_INIT_D/adblock-lean" start >/dev/null 2>&1
                "$ETC_INIT_D/dnsmasq" restart >/dev/null 2>&1
                echo '{"status": "adblock reloaded"}'
                ;;
            *)
                echo '{"error": "unknown service"}'
                ;;
        esac
        ;;

    # ------------------------------------------------------------------
    set_blocklist_tier)
        TIER=$(jf '@.tier')
        if ! cheburnet_valid_tier "$TIER"; then
            echo '{"error": "tier must be one of: light, normal, pro, pro.plus, ultimate, tif, tif.medium, tif.mini, multi.pro, fake"}'; exit 0
        fi

        if [ ! -f "$ETC_ADBLOCK_CFG" ]; then
            echo '{"error": "adblock-lean config not found — установка не завершена"}'; exit 0
        fi

        # Заменяем строку raw_block_lists=... в конфиге
        sed -i "s|^raw_block_lists=.*|raw_block_lists=\"hagezi:${TIER}\"|" "$ETC_ADBLOCK_CFG"

        # Перегенерируем блок-лист (запускается в фоне — не блокирует RPC-ответ)
        ( "$ETC_INIT_D/adblock-lean" start >/dev/null 2>&1
          "$ETC_INIT_D/dnsmasq" restart >/dev/null 2>&1 ) &

        TIER_ESC=$(json_escape "$TIER")
        echo "{\"status\": \"tier set\", \"tier\": \"$TIER_ESC\"}"
        ;;

    # ------------------------------------------------------------------
    factory_reset)
        # Защита от случайного срабатывания: confirm должен быть строго "RESET"
        CONFIRM=$(jf '@.confirm')
        if ! cheburnet_valid_factory_confirm "$CONFIRM"; then
            echo '{"error": "confirm must be exactly \"RESET\""}'; exit 0
        fi

        # Запускаем firstboot отложенно (~3 сек), чтобы успеть отдать RPC-ответ
        # и закрыть сессию. /etc/init.d/done вызывает sysupgrade -r.
        ( sleep 3 && firstboot -y && reboot ) >/dev/null 2>&1 &
        echo '{"status": "factory reset scheduled, router will reboot in ~5 seconds"}'
        ;;

    # ------------------------------------------------------------------
    *)
        echo '{"error": "unknown method"}'
        ;;
esac
